# ── Required ────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Groq / Rate Limiting ────────────────────────────────────────────────────
GROQ_MODEL=llama-3.1-8b-instant
GROQ_RATE_LIMIT=300           # max requests per minute
GROQ_MAX_TOKENS=1024

# ── Semantic Cache ───────────────────────────────────────────────────────────
CACHE_SIMILARITY_THRESHOLD=0.92   # cosine similarity cutoff (0-1)
CACHE_TTL_SECONDS=3600            # cache entry lifetime (1 hour)

# ── Celery Workers ───────────────────────────────────────────────────────────
CELERY_CONCURRENCY=4          # tasks per worker process
MAX_RETRIES=3                 # max retry attempts on failure
TASK_VISIBILITY_TIMEOUT=3600  # seconds before task is requeued if worker silent

# ── API ─────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
